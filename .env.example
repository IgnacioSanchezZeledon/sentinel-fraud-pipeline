# ============================================================
# sentinel-fraud-pipeline — Environment Variables
# ============================================================
# Copy to .env before running: cp .env.example .env

# ---- Kafka (Phase 1) ----
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=transactions
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_NUM_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# ---- Zookeeper (Phase 1) ----
ZOOKEEPER_CLIENT_PORT=2181

# ---- MinIO / S3 (Phase 1) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_PORT=9001
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# ---- MinIO Buckets (Phase 1) ----
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold
MLFLOW_BUCKET=mlflow

# ---- Spark (Phase 1) ----
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2

# ---- Postgres (Phase 1, used by Airflow in Phase 6) ----
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_PORT=5432

# ---- Producer (Phase 2) ----
# PRODUCER_MODE=slow          # slow | fast | realistic
# PRODUCER_LIMIT=0            # 0 = all rows
# PRODUCER_CSV_PATH=data/creditcard.csv

# ---- Bronze Consumer (Phase 2) ----
# BRONZE_CHECKPOINT_PATH=s3a://bronze/checkpoints/transactions/
# BRONZE_OUTPUT_PATH=s3a://bronze/transactions/

# ---- Silver (Phase 3) ----
# SILVER_INPUT_PATH=s3a://bronze/transactions/
# SILVER_OUTPUT_PATH=s3a://silver/transactions/

# ---- MLflow (Phase 4) ----
# MLFLOW_TRACKING_URI=http://mlflow:5000
# MLFLOW_S3_ENDPOINT_URL=http://minio:9000
# MLFLOW_ARTIFACT_ROOT=s3://mlflow/artifacts
# MLFLOW_MODEL_NAME=sentinel-fraud-model

# ---- Gold (Phase 5) ----
# GOLD_OUTPUT_PATH=s3a://gold/

# ---- Airflow (Phase 6) ----
# AIRFLOW__CORE__EXECUTOR=LocalExecutor
# AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
# AIRFLOW__CORE__FERNET_KEY=auto-generated-on-first-run
# AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8081
# AIRFLOW_ADMIN_USER=admin
# AIRFLOW_ADMIN_PASSWORD=admin

# ---- Grafana (Phase 7) ----
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=admin
# GF_SERVER_HTTP_PORT=3000
